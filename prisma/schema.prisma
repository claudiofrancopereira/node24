// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patrimonies {
  id      String @id @default(uuid())
  name    String
  address String

  latitude  Float
  longitude Float

  neighborhood String?
  zipcode      String?

  notes String?

  color String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  images Images[]

  reports Reports[]
}

model Images {
  id        String   @id @default(uuid())
  name      String
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  patrimonies   Patrimonies @relation(fields: [patrimoniesID], references: [id])
  patrimoniesID String
}

model Reports {
  id          String   @id @default(uuid())
  description String
  outcome     String
  opened      Boolean
  createAt    DateTime @default(now())

  patrimony   Patrimonies @relation(fields: [patrimonyID], references: [id])
  patrimonyID String

  reportImages ReportImages[]
}

model ReportImages {
  id        String   @id @default(uuid())
  path      String?
  createdAt DateTime @default(now())

  reports  Reports @relation(fields: [reportID], references: [id])
  reportID String
}
